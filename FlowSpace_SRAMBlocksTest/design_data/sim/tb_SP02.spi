.ic v(xtop.xcolumnblock.xcolumn[1].xperiph.xclkwe.xweff._dff_s)=0.0
.save vss vdd
.save clk
.save "a[0]" "a[1]" "a[2]" "a[3]" "a[4]" "a[5]" "a[6]" "a[7]"
.save "d[0]" "d[1]" "d[2]" "d[3]" "d[4]" "d[5]" "d[6]" "d[7]"
